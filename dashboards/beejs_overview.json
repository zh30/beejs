      {
        "id": 8,
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        },
        "targets": [
          {
            "expr": "rate(beejs_errors_total{instance=\"$instance\"}[$__interval]) / rate(beejs_scripts_executed_total{instance=\"$instance\"}[$__interval]) * 100",
