{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": {
      "pattern": "((^\\s*\\/\\*)?\\s*\\/\\*|\\{\\s*)$",
      "flags": ""
    },
    "decreaseIndentPattern": {
      "pattern": "(\\s*\\}|^\\s*\\/\\*)",
      "flags": ""
    }
  },
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#?region",
      "end": "^\\s*//\\s*#?endregion"
    }
  },
  "wordWrap": "off",
  "formatRules": {
    "enable": true,
    "provider": "beejs"
  }
}
