/// Debug event types
#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum DebugEvent {
    BreakpointHit {
        file: String,
        line: u32,
    },
    VariableChanged {
        name: String,
        old_value: String,
        new_value: String,
    },
    ExecutionPaused,
    ExecutionContinued,
}
