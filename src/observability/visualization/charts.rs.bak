            data: {
                let data_points: Vec<DataPoint> = data.into_iter()
                    .enumerate()
                    .map(|(i, y)| DataPoint {
                        x: i as f64,
                        y,
                        label: None,
                        color: None,
                        metadata: HashMap::new(),
                    })
                    .collect();
                data_points
            },
            color: Some(self.color_palette.primary.clone()),
            visible: true,
            line_style: LineStyle::default(),
        };
        self.data.push(series);
        self
    }
    /// Build the chart
    pub fn build(&mut self) -> Result<BarChart> {
