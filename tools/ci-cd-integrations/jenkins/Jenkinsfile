// Beejs Jenkins Pipeline
// This Jenkinsfile provides CI/CD integration for Beejs projects

pipeline {
    agent any

    environment {
        BEEJS_VERSION = 'latest'
        NODE_VERSION = '18'
        DOCKER_REGISTRY = 'your-registry.com'
        IMAGE_NAME = 'beejs-app'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    println '📦 Checking out source code...'
                }
                checkout scm
            }
        }

        stage('Setup Beejs') {
            steps {
                script {
                    println '🐝 Setting up Beejs runtime...'

                    // Download and install Beejs
                    sh '''
                        curl -L "https://github.com/beejs-team/beejs/releases/download/v0.1.0/bee-linux-x64.tar.gz" -o bee.tar.gz
                        tar -xzf bee.tar.gz
                        chmod +x bee
                        sudo mv bee /usr/local/bin/
                    '''

                    // Verify installation
                    sh 'bee --version'
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                script {
                    println '📦 Installing dependencies...'

                    // Use appropriate package manager
                    if (fileExists('package.json')) {
                        sh 'npm ci'
                    } else if (fileExists('yarn.lock')) {
                        sh 'yarn install --frozen-lockfile'
                    } else if (fileExists('pnpm-lock.yaml')) {
                        sh 'pnpm install --frozen-lockfile'
                    }
                }
            }
        }

        stage('Lint') {
            steps {
                script {
                    println '🔍 Running linter...'

                    // Run linter with Beejs
                    sh '''
                        if [ -f .eslintrc.js ] || [ -f .eslintrc.json ]; then
                            bee run node_modules/.bin/eslint src/ --format=json --output-file=eslint-results.json
                        fi
                    '''
                }

                // Archive lint results
                archiveArtifacts artifacts: 'eslint-results.json', allowEmptyArchive: true
                publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: '.',
                    reportFiles: 'eslint-results.json',
                    reportName: 'ESLint Report'
                ])
            }
        }

        stage('Test') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        script {
                            println '🧪 Running unit tests...'

                            // Run tests with Beejs
                            sh '''
                                bee test --reporter=json --output=test-results.json
                            '''
                        }

                        // Publish test results
                        publishTestResults testResultsPattern: 'test-results.json'
                    }
                }

                stage('Integration Tests') {
                    steps {
                        script {
                            println '🔗 Running integration tests...'

                            // Run integration tests
                            sh '''
                                bee test tests/integration --reporter=json --output=integration-results.json
                            '''
                        }

                        publishTestResults testResultsPattern: 'integration-results.json'
                    }
                }

                stage('Performance Tests') {
                    steps {
                        script {
                            println '⚡ Running performance tests...'

                            // Run performance benchmarks
                            sh '''
                                bee run benchmarks/comprehensive_benchmark.js > performance-results.txt 2>&1
                            '''
                        }

                        archiveArtifacts artifacts: 'performance-results.txt', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Build') {
            steps {
                script {
                    println '🔨 Building application...'

                    // Build with Beejs
                    sh '''
                        # TypeScript compilation
                        if [ -f tsconfig.json ]; then
                            bee run build.ts
                        fi

                        # Bundle JavaScript
                        if [ -f src/index.js ]; then
                            bee bundle src/index.js --outfile=dist/bundle.js --minify
                        fi
                    '''

                    // Archive build artifacts
                    archiveArtifacts artifacts: 'dist/**', allowEmptyArchive: true
                }
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    println '🔒 Running security scan...'

                    // Run security scan
                    sh '''
                        bee run scripts/security-scan.js > security-report.txt 2>&1 || true
                    '''

                    archiveArtifacts artifacts: 'security-report.txt', allowEmptyArchive: true
                }
            }
        }

        stage('Docker Build') {
            when {
                anyOf {
                    branch 'main'
                    branch 'develop'
                    changeRequest()
                }
            }
            steps {
                script {
                    println '🐳 Building Docker image...'

                    docker.build("${IMAGE_NAME}:${IMAGE_TAG}")
                    docker.build("${IMAGE_NAME}:latest")
                }
            }
        }

        stage('Push to Registry') {
            when {
                anyOf {
                    branch 'main'
                    branch 'develop'
                    changeRequest()
                }
            }
            steps {
                script {
                    println '📤 Pushing to Docker registry...'

                    withDockerRegistry(credentialsId: 'docker-registry') {
                        docker.image("${IMAGE_NAME}:${IMAGE_TAG}").push()
                        docker.image("${IMAGE_NAME}:latest").push()
                    }
                }
            }
        }

        stage('Deploy to Staging') {
            when {
                branch 'develop'
            }
            steps {
                script {
                    println '🚀 Deploying to staging environment...'

                    // Deploy to staging
                    sh '''
                        echo "Deploying to staging..."
                        # Add your deployment commands here
                        # Example: kubectl apply -f k8s/staging/
                    '''
                }
            }
        }

        stage('Deploy to Production') {
            when {
                branch 'main'
            }
            steps {
                script {
                    println '🚀 Deploying to production...'

                    // Deploy to production
                    sh '''
                        echo "Deploying to production..."
                        # Add your deployment commands here
                        # Example: kubectl apply -f k8s/production/
                    '''
                }

                // Send notification
                emailext (
                    subject: "✅ Beejs Build #${BUILD_NUMBER} - Production Deployment",
                    body: "Production deployment successful for build #${BUILD_NUMBER}",
                    to: "${env.CHANGE_AUTHOR_EMAIL}"
                )
            }
        }

        stage('Post-Build Actions') {
            parallel {
                stage('Generate Report') {
                    steps {
                        script {
                            println '📊 Generating build report...'

                            // Generate comprehensive report
                            sh '''
                                bee run scripts/generate-build-report.js \
                                    --build-number=${BUILD_NUMBER} \
                                    --commit=${GIT_COMMIT} \
                                    --branch=${GIT_BRANCH} \
                                    > build-report.html
                            '''
                        }

                        // Publish HTML report
                        publishHTML([
                            allowMissing: false,
                            alwaysLinkToLastBuild: true,
                            keepAll: true,
                            reportDir: '.',
                            reportFiles: 'build-report.html',
                            reportName: 'Build Report'
                        ])
                    }
                }

                stage('Cleanup') {
                    steps {
                        script {
                            println '🧹 Cleaning up...'

                            // Clean up temporary files
                            sh '''
                                rm -f bee.tar.gz
                                docker system prune -f
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                println '📋 Post-build actions...'

                // Archive all test results
                archiveArtifacts artifacts: '**/*.json,**/*.txt,**/*.html', allowEmptyArchive: true

                // Publish test results if available
                if (fileExists('test-results.json')) {
                    publishTestResults testResultsPattern: 'test-results.json'
                }
            }
        }

        success {
            script {
                println '✅ Build succeeded!'
                // Add success actions here
            }
        }

        failure {
            script {
                println '❌ Build failed!'

                // Send failure notification
                emailext (
                    subject: "❌ Beejs Build #${BUILD_NUMBER} Failed",
                    body: "Build #${BUILD_NUMBER} failed. Check console output for details.",
                    to: "${env.CHANGE_AUTHOR_EMAIL}"
                )
            }
        }

        unstable {
            script {
                println '⚠️ Build unstable'
                // Add unstable handling here
            }
        }
    }
}
