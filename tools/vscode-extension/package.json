{
  "name": "beejs-vscode",
  "displayName": "Beejs Runtime Support",
  "description": "VS Code extension for Beejs - High-performance JavaScript/TypeScript runtime",
  "version": "0.1.0",
  "publisher": "beejs-team",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "keywords": [
    "javascript",
    "typescript",
    "runtime",
    "beejs",
    "debugger",
    "performance"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onCommand:beejs.runScript",
    "onDebug:beejs"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "beejs",
        "aliases": ["Beejs", "beejs"],
        "extensions": [".beejs"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "beejs",
        "scopeName": "source.beejs",
        "path": "./syntaxes/beejs.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Beejs Runtime",
      "properties": {
        "beejs.runtimePath": {
          "type": "string",
          "default": "bee",
          "description": "Path to the Beejs executable",
          "order": 1
        },
        "beejs.debugPort": {
          "type": "number",
          "default": 9229,
          "description": "Debug port for Beejs inspector",
          "order": 2
        },
        "beejs.enableTypeChecking": {
          "type": "boolean",
          "default": true,
          "description": "Enable TypeScript type checking for Beejs scripts",
          "order": 3
        },
        "beejs.maxMemory": {
          "type": "string",
          "default": "512m",
          "description": "Maximum memory allocation for Beejs runtime",
          "order": 4
        },
        "beejs.enableExperimentalFeatures": {
          "type": "boolean",
          "default": false,
          "description": "Enable experimental Beejs features",
          "order": 5
        }
      }
    },
    "commands": [
      {
        "command": "beejs.runScript",
        "title": "Run Beejs Script",
        "category": "Beejs"
      },
      {
        "command": "beejs.debugScript",
        "title": "Debug Beejs Script",
        "category": "Beejs"
      },
      {
        "command": "beejs.showPerformanceReport",
        "title": "Show Performance Report",
        "category": "Beejs"
      },
      {
        "command": "beejs.installRuntime",
        "title": "Install Beejs Runtime",
        "category": "Beejs"
      }
    ],
    "keybindings": [
      {
        "command": "beejs.runScript",
        "key": "f5",
        "when": "editorTextFocus && resourceExtname == .js"
      },
      {
        "command": "beejs.debugScript",
        "key": "f6",
        "when": "editorTextFocus && resourceExtname == .js"
      }
    ],
    "debuggers": [
      {
        "type": "beejs",
        "label": "Beejs",
        "program": "./out/debug/adapter.js",
        "runtimeExecutable": "${config:beejs.runtimePath}",
        "runtimeArgs": ["debug", "--port", "${config:beejs.debugPort}"],
        "port": "${config:beejs.debugPort}",
        "stopOnEntry": true,
        "sourceMaps": true,
        "pathMappings": [],
        "restart": true,
        "console": "integratedTerminal",
        "variables": {
          "beejsRuntime": "${command:beejs.selectRuntime}"
        }
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "beejs.runScript",
          "when": "resourceExtname == .js || resourceExtname == .ts || resourceExtname == .beejs",
          "group": "beejs@1"
        },
        {
          "command": "beejs.debugScript",
          "when": "resourceExtname == .js || resourceExtname == .ts || resourceExtname == .beejs",
          "group": "beejs@2"
        }
      ],
      "explorer/context": [
        {
          "command": "beejs.runScript",
          "when": "resourceExtname == .js || resourceExtname == .ts || resourceExtname == .beejs",
          "group": "beejs@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "18.x",
    "@types/mocha": "^10.0.0",
    "@types/chai": "^4.3.0",
    "typescript": "^4.9.4",
    "ts-node": "^10.9.1",
    "mocha": "^10.2.0",
    "chai": "^4.3.7",
    "eslint": "^8.34.0",
    "@typescript-eslint/eslint-plugin": "^5.53.0",
    "@typescript-eslint/parser": "^5.53.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.61.0",
    "@vscode/debugprotocol": "^1.61.0",
    "vscode-languageclient": "^8.1.0",
    "vscode-languageprotocol": "^1.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/beejs-team/beejs-vscode.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/beejs-team/beejs-vscode/issues"
  },
  "homepage": "https://github.com/beejs-team/beejs-vscode#readme"
}
