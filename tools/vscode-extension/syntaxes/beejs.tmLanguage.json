{
  "name": "Beejs",
  "scopeName": "source.beejs",
  "patterns": [
    {
      "include": "#beejs-keywords"
    },
    {
      "include": "#beejs-globals"
    },
    {
      "include": "source.js"
    }
  ],
  "repository": {
    "beejs-keywords": {
      "patterns": [
        {
          "name": "keyword.control.beejs",
          "match": "\\b(beejs)\\b"
        },
        {
          "name": "keyword.operator.beejs",
          "match": "\\.(run|bundle|test|profile|benchmark|compile)\\b"
        },
        {
          "name": "support.function.beejs",
          "match": "\\bbeejs\\.(run|bundle|test|profile|benchmark|compile)\\b"
        }
      ]
    },
    "beejs-globals": {
      "patterns": [
        {
          "name": "variable.language.beejs",
          "match": "\\bbeejs\\b"
        },
        {
          "name": "meta.function.call.beejs",
          "match": "\\b(beejs\\.(run|bundle|test|profile|benchmark|compile))\\s*(?=\\()"
        }
      ]
    }
  },
  "uuid": "beejs-syntax-highlighting"
}
